{
  "name": "my-ai-navigator",
  "private": true,
  "version": "1.0.0",
  "description": "AI Navigator 2026 — AI 行业全景导航器，涵盖文本、视觉、视频、音频、具身智能与算力硬件六大前沿赛道",
  "author": "billowssun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/billowssun/ai-knowledge-pro.git"
  },
  "homepage": "https://github.com/billowssun/ai-knowledge-pro#readme",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.10",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.2.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.9",
    "vitest": "^3.1.5"
  }
}
